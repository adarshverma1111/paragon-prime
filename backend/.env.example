# ──────────────────────────────────────────────
#  Paragon Prime Infotech — Backend .env
# ──────────────────────────────────────────────

# Port the Express server will run on
PORT=5000

# ── Gmail SMTP credentials ──────────────────
# Use the Gmail address that will SEND emails
MAIL_USER=your_gmail@gmail.com

# Generate an App Password at:
# https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be ON)
MAIL_PASS=your_16_char_app_password

# ── Recipient ───────────────────────────────
# The email address that RECEIVES form submissions
# (can be same as MAIL_USER or a different address)
OWNER_EMAIL=connect@paragonprimeinfotech.com

# ── Frontend URL (for CORS) ─────────────────
# Set this to your deployed frontend domain in production
FRONTEND_URL=http://localhost:3000
